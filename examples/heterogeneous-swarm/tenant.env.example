# Shared token used by both sessions (CLAUDE-SPEC and DEEPSEEK-IMPL).
# Token = tenant identity. Same token = same tenant = sessions see each other.
# New token = new isolated tenant.
#
# Setup:
#   1. Run a myco daemon somewhere accessible:
#        python3 ~/myco/prototype/mycod.py --port 8000 /tmp/myco-swarm
#   2. Copy this file to tenant.env and fill in:
#        cp tenant.env.example tenant.env
#   3. Generate a fresh token (any 32+ char string with enough entropy):
#        export TOKEN="heterogeneous-swarm-$(openssl rand -hex 24)"
#   4. Edit tenant.env: set MYCO_URL to your daemon's address and paste the token

export MYCO_URL="http://127.0.0.1:8000"
export MYCO_TOKEN="REPLACE-ME-with-a-fresh-32+-char-token"
